# Copy to .env on the EC2 instance (never commit the real file — same
# convention as apps/web/.env and services/scraper/.env). Consumed by
# docker-compose.prod.yml.

# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=
FREELLMAPI_ENCRYPTION_KEY=

# Domain's A record must already point at this EC2 instance's public IP
# before first boot, or Let's Encrypt's issuance will fail.
DOMAIN=zobhira.com
# Separate subdomain for the admin app (apps/admin) — needs its own A
# record too, pointing at the same instance IP.
ADMIN_DOMAIN=admin.zobhira.com
ACME_EMAIL=you@zobhira.com

# --- Admin app: Firebase (see apps/admin/src/lib/firebase.ts / firebase-admin.ts) ---
# Client SDK config — public identifiers, safe to expose. Get these from
# Firebase Console > Project Settings > General > Your apps > Web app.
# Required at *build* time (docker-compose.prod.yml passes them as the
# admin service's build args, not just runtime env — see that file).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Admin SDK service-account creds — server-only secret, from Firebase Console >
# Project Settings > Service Accounts > Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Keep the \n escapes literal (don't unescape them) — paste the private_key
# field from the downloaded JSON as one double-quoted line.
FIREBASE_ADMIN_PRIVATE_KEY=

# Comma-separated list of Google account emails allowed into the admin app.
ADMIN_ALLOWED_EMAILS=

# FreeLLMAPI's own unified key — obtained from its dashboard after first
# boot (see deploy/DEPLOY.md). Leave blank until then; the scraper's LLM
# fallback path just skips it if unset.
FREELLMAPI_API_KEY=

# Optional direct-provider fallback, tried only if FreeLLMAPI itself is
# unreachable. All independently optional — deterministic scraping (the
# primary path for every source) works with none of these set.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- OpenWA (self-hosted WhatsApp API, https://github.com/rmyndharis/OpenWA) ---
# No domain needed — not published through nginx-proxy (see docker-compose.prod.yml's
# comment on this service for why: its docker-socket-proxy sidecar grants it
# container-creation rights, so it deliberately stays off the public internet).
# n8n reaches it internally; you reach its dashboard via SSH port-forward
# (see deploy/DEPLOY.md).
# Generate with: openssl rand -hex 32
OPENWA_API_MASTER_KEY=

# --- n8n (self-hosted workflow automation) ---
# Needs its own A record too.
N8N_DOMAIN=n8n.zobhira.com
# Generate with: openssl rand -hex 32 — encrypts n8n's stored credentials.
# Losing/changing this after n8n has saved credentials makes them
# unreadable, so back it up alongside POSTGRES_PASSWORD.
N8N_ENCRYPTION_KEY=
N8N_BASIC_AUTH_USER=
# Generate with: openssl rand -hex 20
N8N_BASIC_AUTH_PASSWORD=
# Only needed if UTC is wrong for scheduled workflows.
N8N_TIMEZONE=UTC

# --- Dispatch (outbound job/contest posting to Telegram etc. via n8n) ---
# Shared secret guarding apps/web's /api/dispatch/* endpoints. n8n sends it as
# the X-Dispatch-Key header from inside the compose network. Generate with:
# openssl rand -hex 32
DISPATCH_API_KEY=
